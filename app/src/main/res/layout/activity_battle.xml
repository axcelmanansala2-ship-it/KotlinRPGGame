<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060618">

    <!-- Game Canvas -->
    <com.example.kotlinrpg.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.2"/>

    <!-- HP Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#161630"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <TextView
            android:id="@+id/tvHeroHp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HERO  HP: 100/100"
            android:textColor="#44FF44"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvEnemyHp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Slime  HP: 40/40"
            android:textColor="#FF5555"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Battle Log -->
    <ScrollView
        android:id="@+id/svLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.9"
        android:background="#0a0a18"
        android:padding="8dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCDD"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.5"/>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        android:background="#0d0d22">

        <Button
            android:id="@+id/btnAttack"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="⚔ ATTACK"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#CC2222"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnDefend"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="🛡 DEFEND"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#1155CC"
            android:layout_marginEnd="3dp"/>

        <Button
            android:id="@+id/btnHeal"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="🧪 HEAL (x3)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#228833"/>
    </LinearLayout>
</LinearLayout>
