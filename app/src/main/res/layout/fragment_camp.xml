<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050510"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CAMP"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#CC0033"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.16"
        android:paddingBottom="12dp"/>

    <TextView
        android:id="@+id/tvGold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gold: 0"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFDD00"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="14dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/btnBuyPotion"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="POTION\n30g"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#22CC66"
            android:gravity="center"
            android:background="#0A180A"
            android:layout_marginEnd="4dp"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:id="@+id/btnRest"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="REST\n20g"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#6688CC"
            android:gravity="center"
            android:background="#0A0A18"
            android:lineSpacingMultiplier="1.2"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/btnUpgradeAtk"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="ATK UP\n+2"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#CC4444"
            android:gravity="center"
            android:background="#180A0A"
            android:layout_marginEnd="4dp"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:id="@+id/btnUpgradeDef"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="DEF UP\n+1"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#4488CC"
            android:gravity="center"
            android:background="#0A0A18"
            android:layout_marginEnd="4dp"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:id="@+id/btnUpgradeHp"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="HP UP\n+20"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#33CC55"
            android:gravity="center"
            android:background="#0A180A"
            android:lineSpacingMultiplier="1.2"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0A0A16"
        android:padding="12dp">
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.7"/>
    </ScrollView>
</LinearLayout>
