<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#060618">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#9876;"
        android:textSize="72sp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIXEL RPG"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:fontFamily="monospace"
        android:letterSpacing="0.12"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kotlin Edition"
        android:textSize="15sp"
        android:textColor="#8888AA"
        android:fontFamily="monospace"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5 Enemies to defeat:"
        android:textSize="13sp"
        android:textColor="#AAAACC"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Slime  &#8250;  Goblin  &#8250;  Skeleton\nDark Knight  &#8250;  Dragon"
        android:textSize="13sp"
        android:textColor="#8888AA"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnPlay"
        android:layout_width="220dp"
        android:layout_height="60dp"
        android:text="START GAME"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:backgroundTint="#CC2222"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Attack  |  Defend  |  Heal"
        android:textSize="12sp"
        android:textColor="#555577"
        android:fontFamily="monospace"
        android:layout_marginTop="28dp"/>
</LinearLayout>
