<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="#04040F">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#9760;"
        android:textSize="72sp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DARK REALM"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#CC0033"
        android:fontFamily="monospace"
        android:letterSpacing="0.18"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Idle RPG"
        android:textSize="14sp"
        android:textColor="#441144"
        android:fontFamily="monospace"
        android:layout_marginBottom="6dp"/>

    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="#33CC0033"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3-Hero Formation Battles\nAFK Idle Progression\n6 Dark Zones to Conquer\n5 Hero Classes to Unlock\nSlide Screen Navigation"
        android:textSize="12sp"
        android:textColor="#5555AA"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingMultiplier="1.8"
        android:layout_marginBottom="36dp"/>

    <TextView
        android:id="@+id/btnPlay"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="&#9654;  CONTINUE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#FFDD00"
        android:gravity="center"
        android:background="#CC1A0022"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/btnNewGame"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:text="NEW GAME"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textColor="#886699"
        android:gravity="center"
        android:background="#880D0D18"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kotlin Edition  v3.0"
        android:textSize="10sp"
        android:textColor="#222233"
        android:fontFamily="monospace"
        android:layout_marginTop="28dp"/>
</LinearLayout>
