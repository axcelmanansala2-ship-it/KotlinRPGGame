<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050510">

    <TextView
        android:id="@+id/tvIdleInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Zone: —  •  Idle: —"
        android:textColor="#556655"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:padding="5dp"
        android:background="#08080F"/>

    <com.example.kotlinrpg.BattleView
        android:id="@+id/battleView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.2"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lv.1 Hero  HP:100/100"
        android:textColor="#44FF88"
        android:fontFamily="monospace"
        android:textSize="10sp"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:paddingVertical="5dp"
        android:background="#0D0D1A"
        android:singleLine="false"/>

    <ScrollView
        android:id="@+id/svLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.85"
        android:background="#080812"
        android:padding="8dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.5"/>
    </ScrollView>

    <TextView
        android:id="@+id/btnPotion"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="POTION (5)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#22CC66"
        android:gravity="center"
        android:background="#0D1A0D"/>
</LinearLayout>
