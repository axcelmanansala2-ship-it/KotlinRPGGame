<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#04040F">

    <TextView
        android:id="@+id/tvWave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wave 1"
        android:textColor="#AA44FF"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="5dp"
        android:paddingBottom="3dp"
        android:letterSpacing="0.12"
        android:background="#08080F"/>

    <com.example.kotlinrpg.BattleView
        android:id="@+id/battleView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.4"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#44FF88"
        android:fontFamily="monospace"
        android:textSize="9sp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:background="#0C0C1A"/>

    <ScrollView
        android:id="@+id/svLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.65"
        android:background="#070712"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#7788AA"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:lineSpacingMultiplier="1.4"/>
    </ScrollView>

    <TextView
        android:id="@+id/btnPotion"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="POTION (5)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#22CC66"
        android:gravity="center"
        android:background="#0C180C"/>
</LinearLayout>
