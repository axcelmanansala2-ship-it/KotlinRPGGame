<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050510"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CHOOSE YOUR HERO"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#CC0033"
        android:fontFamily="monospace"
        android:gravity="center"
        android:letterSpacing="0.14"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/cardKnight"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:text="&#9876;\nKNIGHT"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#888899"
            android:gravity="center"
            android:background="#0D0D18"
            android:layout_marginEnd="4dp"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/cardMage"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:text="&#10024;\nMAGE"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#888899"
            android:gravity="center"
            android:background="#0D0D18"
            android:layout_marginEnd="4dp"
            android:lineSpacingMultiplier="1.4"/>

        <TextView
            android:id="@+id/cardArcher"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:text="&#127993;\nARCHER"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="#888899"
            android:gravity="center"
            android:background="#0D0D18"
            android:lineSpacingMultiplier="1.4"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0A0A16"
        android:padding="12dp">
        <TextView
            android:id="@+id/tvClassDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAACC"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.7"/>
    </ScrollView>

    <TextView
        android:id="@+id/btnStartAdventure"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="BEGIN ADVENTURE"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:textColor="#FFDD00"
        android:gravity="center"
        android:background="#CC220033"
        android:layout_marginTop="12dp"/>
</LinearLayout>
